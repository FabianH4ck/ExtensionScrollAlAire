{
  "manifest_version": 3,
  "name": "ScrollSense",
  "version": "1.1.0",
  "description": "Haz scroll en TikTok, YouTube Shorts e Instagram moviendo el dedo frente a la camara.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://www.tiktok.com/*",
    "https://www.instagram.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/IconoDef.png",
      "48": "icons/IconoDef.png",
      "128": "icons/IconoDef.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://www.tiktok.com/*",
        "https://www.instagram.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "trustedtypes.js",
        "injected.js",
        "mediapipe/hands/*",
        "mediapipe/camera_utils/*"
      ],
      "matches": [
        "https://www.youtube.com/*",
        "https://www.tiktok.com/*",
        "https://www.instagram.com/*"
      ]
    }
  ]
}
